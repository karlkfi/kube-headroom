#!/usr/bin/env bash
set -euo pipefail
root="$(git rev-parse --show-toplevel)"

# Backlog format checks (isolated docs(status): commits only).
"$root/scripts/lint-backlog.sh" --staged

# gofmt check on staged Go files (sub-second). Reject the commit if any staged
# .go file is not gofmt-clean; run `gofmt -w <file>` and re-stage to fix.
# Bypass a single commit with `git commit --no-verify`.
#
# Fast local subset, not the full gate: `make lint` (CI) additionally enforces
# goimports via golangci-lint. We use bare gofmt here on purpose — it ships with
# the Go toolchain (instant, no build step), whereas goimports only exists
# inside the pinned golangci-lint binary and would make the hook slow and
# dependent on `make golangci-lint` having been run. CI catches any import
# ordering this misses.
# NUL-delimited + a while-read loop so this stays correct under bash 3.2
# (macOS default, which lacks `mapfile`) and for odd filenames.
go_files=()
while IFS= read -r -d '' f; do
	go_files+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACM -z -- '*.go')

if [ "${#go_files[@]}" -gt 0 ]; then
	unformatted="$(cd "$root" && gofmt -l -- "${go_files[@]}")"
	if [ -n "$unformatted" ]; then
		echo "gofmt: the following staged Go files are not formatted:" >&2
		echo "$unformatted" | sed 's/^/  /' >&2
		echo "Run 'gofmt -w' on them and re-stage, or commit with --no-verify." >&2
		exit 1
	fi
fi
